{
  "display_information": {
    "name": "Morgenruf",
    "description": "Self-hosted daily standup bot \u2014 AI summaries, analytics, and MCP for AI tools",
    "background_color": "#0d1117"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": true
    },
    "bot_user": {
      "display_name": "Morgenruf",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/standup",
        "description": "Start your daily standup now",
        "url": "https://api.morgenruf.dev/slack/events"
      },
      {
        "command": "/skip",
        "description": "Skip today's standup",
        "url": "https://api.morgenruf.dev/slack/events"
      },
      {
        "command": "/kudos",
        "description": "Give a shoutout to a teammate",
        "usage_hint": "@teammate [message]",
        "url": "https://api.morgenruf.dev/slack/events"
      },
      {
        "command": "/help",
        "description": "Show Morgenruf commands and help",
        "url": "https://api.morgenruf.dev/slack/events"
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "https://api.morgenruf.dev/oauth/callback"
    ],
    "scopes": {
      "bot": [
        "chat:write",
        "im:history",
        "im:read",
        "im:write",
        "channels:read",
        "channels:history",
        "groups:read",
        "reactions:write",
        "users:read",
        "users:read.email",
        "team:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.im",
        "app_mention",
        "app_home_opened",
        "member_joined_channel"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false
  }
}