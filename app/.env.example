# PostgreSQL
DATABASE_URL=postgresql://morgenruf:password@localhost:5432/morgenruf

# Resend (optional - welcome emails)
RESEND_API_KEY=re_xxxx

# App
PORT=3000
APP_URL=https://api.morgenruf.dev
